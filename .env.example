PDF_SERVICES_CLIENT_ID=your_client_id_here
PDF_SERVICES_CLIENT_SECRET=your_client_secret_here

# Optional: Roboflow hosted DocLayout-YOLO backend.
# Get a key from https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL=jaswanth-kwujz/doclayout-yolo/3

# Optional: MinerU Cloud backend (opendatalab official hosted pipeline).
# Get a token at https://mineru.net/apiManage/token
MINERU_API_TOKEN=

# Optional: Datalab Marker API backend.
# Get a key at https://www.datalab.to/app/keys
DATALAB_API_KEY=

# Optional: LlamaParse (LlamaIndex Cloud) backend.
# Get a key at https://cloud.llamaindex.ai/api-key
LLAMAPARSE_API_KEY=

# Optional: Upstage Document Parse backend.
# Get a key at https://console.upstage.ai/api-keys
UPSTAGE_API_KEY=

# Optional: GLM (Zhipu AI) multimodal-LLM OCR backend.
# Get a key at https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=
GLM_MODEL=glm-4v
